{
  "name": "union-codepet",
  "version": "0.3.0",
  "description": "Unified CLI status monitor + desktop pet config UI for Claude Code / Codex / Zcode.",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist:win": "electron-vite build && electron-builder --win",
    "pack": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pack.ps1",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "keywords": [
    "claude-code",
    "codex",
    "zcode",
    "desktop-pet",
    "notify",
    "hooks",
    "electron"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.unioncodepet.app",
    "productName": "UnionCodePet",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      { "from": "pets", "to": "pets" },
      { "from": "build", "to": "build" }
    ],
    "win": {
      "target": [
        { "target": "dir", "arch": ["x64"] }
      ],
      "icon": "build/UnionCodePet-icon-source.png"
    }
  }
}

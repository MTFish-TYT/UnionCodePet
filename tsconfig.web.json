{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/*"]
    },
    "outDir": "./out/tsc-web",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"]
  },
  "include": ["renderer/src/**/*.ts", "renderer/src/**/*.tsx", "src/protocol.ts", "src/config.ts"],
  "exclude": ["node_modules", "out", "dist", "dist-legacy", "electron"]
}
